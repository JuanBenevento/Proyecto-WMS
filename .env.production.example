# =============================================================================
# WMS Enterprise - Production Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# =============================================================================
# Database (REQUIRED)
# =============================================================================
DB_NAME=wms_db
DB_USER=postgres
DB_PASSWORD=changeme_secure_password_here

# =============================================================================
# Security (REQUIRED - MUST be changed!)
# =============================================================================
# Generate a secure key: openssl rand -base64 32
JWT_SECRET_KEY=changeme_generate_secure_key_here_min_256bits
JWT_EXPIRATION=86400000

# =============================================================================
# Multi-Tenant (RECOMMENDED for production)
# =============================================================================
WMS_TENANT_ISOLATION_ENABLED=true
WMS_TENANT_RLS_ENABLED=true

# =============================================================================
# URLs (RECOMMENDED)
# =============================================================================
API_URL=http://localhost:8080/api/v1

# =============================================================================
# Ports
# =============================================================================
BACKEND_PORT=8080
FRONTEND_PORT=80

# =============================================================================
# Logging
# =============================================================================
LOGGING_FORMAT=json

# =============================================================================
# Grafana (Optional)
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password_here