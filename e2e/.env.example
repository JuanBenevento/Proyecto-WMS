# WMS E2E Test Configuration
# Copy to .env and configure for your environment

# Backend API
API_URL=http://localhost:8080

# Frontend UI  
FRONTEND_URL=http://localhost:4200

# Test Credentials
TEST_SUPERADMIN_USERNAME=superadmin
TEST_SUPERADMIN_PASSWORD=admin123

TEST_ADMIN_USERNAME=admin
TEST_ADMIN_PASSWORD=admin123

TEST_USER_USERNAME=user
TEST_USER_PASSWORD=user123

# Database (for cleanup between tests)
DB_URL=jdbc:postgresql://localhost:5432/wms_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Test Tenant
TEST_TENANT_ID=demo
TEST_TENANT_NAME=Demo Company